@model List<Geekspace.Models.LearningResource>

@{
    ViewData["Title"] = "Home";
}

<!-- Internal CSS: page-scoped styles for this view only -->
<style>
.hero {
    background: linear-gradient(135deg, var(--gs-hero-start) 0%, var(--gs-hero-end) 100%);
    color: #fff;
    padding: 3.5rem 2rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    box-shadow: 0 8px 24px var(--gs-shadow);
}

.resource-card {
    height: 100%;
}

    .type-badge {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }
</style>

<header class="hero text-center">
    <h1 class="display-5 fw-bold">Welcome to Geekspace</h1>
    <!-- Inline style: a one-off accent, deliberately not worth a CSS class -->
    <p class="lead" style="opacity:0.85;">
        A learning hub for cybersecurity, CTF challenges, and hands-on tech skills.
    </p>
    <a asp-controller="Resource" asp-action="Index" class="btn btn-light btn-lg mt-2">
        Browse All Resources
    </a>
</header>

<section aria-labelledby="latest-resources-heading">
    <h2 id="latest-resources-heading" class="mb-3">Latest Learning Resources</h2>

    @if (!Model.Any())
    {
        <p class="text-muted">No resources have been published yet. Check back soon.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @for (int i = 0; i < Model.Count; i++)
            {
                var resource = Model[i];
                <div class="col">
                    <article class="card resource-card hover-lift fade-in-up" style="animation-delay: @(i * 0.06)s;">
                        @if (!string.IsNullOrWhiteSpace(resource.MediaUrl) &&
                             (resource.MediaUrl.EndsWith(".jpg") || resource.MediaUrl.EndsWith(".png") || resource.MediaUrl.EndsWith(".jpeg")))
                        {
                            <img src="@resource.MediaUrl" class="card-img-top" alt="@resource.Title" style="height:160px; object-fit:cover;" />
                        }
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary type-badge mb-2 align-self-start">@resource.Type</span>
                            <h3 class="h5 card-title">@resource.Title</h3>
                            <p class="card-text text-muted small">@resource.Category?.Name</p>
                            <p class="card-text">@resource.Description</p>
                            <a asp-controller="Resource" asp-action="Details" asp-route-id="@resource.Id"
                               class="btn btn-outline-primary mt-auto">
                                View Resource
                            </a>
                        </div>
                            <footer class="card-footer text-muted small">
                                Added @resource.CreatedDate.ToString("d MMMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("en-US"))
                            </footer>
                    </article>
                </div>
            }
        </div>
    }
</section>

<section class="mt-5" aria-labelledby="about-heading">
    <h2 id="about-heading">About This Platform</h2>
    <p>
        Geekspace brings together articles, videos, virtual labs, simulations, and self-assessments
        for students learning cybersecurity and technology skills. Registered members can join
        discussions on any resource; administrators curate the content library.
    </p>
</section>

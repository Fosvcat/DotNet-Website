@model List<Geekspace.Models.ResourceComment>

@{
    ViewData["Title"] = "My Activity";
}

<h1>My Activity</h1>
<p class="text-muted">Comments you have posted across all learning resources.</p>

@if (!Model.Any())
{
    <p>You haven't posted any comments yet. Browse the <a asp-controller="LearningResource" asp-action="Index">resource library</a> to join a discussion.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Resource</th>
                <th>Comment</th>
                <th>Posted</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var comment in Model)
            {
                <tr>
                    <td>
                        @if (comment.LearningResource != null)
                        {
                            <a asp-controller="LearningResource" asp-action="Details" asp-route-id="@comment.LearningResourceId">
                                @comment.LearningResource.Title
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">(resource removed)</span>
                        }
                    </td>
                    <td>@comment.Content</td>
                    <td>@comment.PostedDate.ToString("g")</td>
                    <td>
                        <form asp-controller="Comment" asp-action="Delete" asp-route-id="@comment.Id" method="post"
                              onsubmit="return confirm('Delete this comment?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <script>
    (function () {
        var savedTheme = localStorage.getItem('geekspace-theme');
        document.documentElement.setAttribute('data-bs-theme', savedTheme || 'light');
    })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="view-transition" content="same-origin" />
    <title>@ViewData["Title"] - Geekspace</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Geekspace.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Geekspace</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <div class="navbar-grid w-100">
                            <ul class="navbar-nav">
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Resource" asp-action="Index">Resources</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="Category" asp-action="Index">Categories</a>
                                </li>
                            </ul>

                            <form class="d-flex justify-content-center" asp-controller="Resource" asp-action="Search" method="get" role="search">
                                <input type="text" name="q" class="form-control form-control-sm search-box"
                                       placeholder="Search resources..." aria-label="Search resources"
                                       value="@Context.Request.Query["q"]" />
                            </form>

                            <div class="d-flex align-items-center justify-content-end">
                                <button id="themeToggle" class="btn theme-toggle-btn me-2" type="button" title="Toggle light / dark theme">
                                    <span id="themeIcon">🌙</span>
                                </button>
                                <partial name="_LoginPartial" />
                            </div>
                        </div>
                    </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Geekspace - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toggleBtn = document.getElementById('themeToggle');
            var icon = document.getElementById('themeIcon');
            var html = document.documentElement;

            function updateIcon() {
                icon.textContent = html.getAttribute('data-bs-theme') === 'dark' ? '☀️' : '🌙';
            }
            updateIcon();

            function applyTheme(next) {
                html.setAttribute('data-bs-theme', next);
                localStorage.setItem('geekspace-theme', next);
                updateIcon();
            }

            toggleBtn.addEventListener('click', function (event) {
                var next = html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';

                // Fallback for browsers without View Transitions support
                // (e.g. older Firefox/Safari): switch instantly, no circular reveal.
                if (!document.startViewTransition) {
                    applyTheme(next);
                    return;
                }

                var rect = toggleBtn.getBoundingClientRect();
                var xPercent = ((rect.left + rect.width / 2) / window.innerWidth) * 100;
                var yPercent = ((rect.top + rect.height / 2) / window.innerHeight) * 100;

                // Percentages, not pixels, on purpose: Chrome's
                // view-transition pseudo-element box does not always
                // correspond 1:1 with actual viewport pixels, which made
                // pixel-based clip-path values land in the wrong spot and
                // stop short of full coverage. Percentages are always
                // resolved relative to the pseudo-element's own box, so
                // they stay correct regardless of its actual rendered size.
                html.style.setProperty('--reveal-x', xPercent + '%');
                html.style.setProperty('--reveal-y', yPercent + '%');

                // Also disable all CSS color transitions for the duration of
                // the theme switch, so elements with their own background/
                // color transitions can't be snapshotted mid-fade.
                html.classList.add('theme-transitioning');

                var transition = document.startViewTransition(function () {
                    applyTheme(next);
                });

                transition.finished.then(function () {
                    html.classList.remove('theme-transitioning');
                    html.style.removeProperty('--reveal-x');
                    html.style.removeProperty('--reveal-y');
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

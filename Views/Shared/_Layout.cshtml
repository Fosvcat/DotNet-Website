<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <script>
    (function () {
        var savedTheme = localStorage.getItem('geekspace-theme');
        document.documentElement.setAttribute('data-bs-theme', savedTheme || 'light');
    })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Geekspace</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Geekspace.styles.css" asp-append-version="true" />
    <style>
        /* Theme transition overlay */
        .theme-transition-circle {
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transform: scale(0);
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .theme-transition-circle.light {
            background-color: #ffffff;
        }
        
        .theme-transition-circle.dark {
            background-color: #212529;
        }
        
        .theme-transition-circle.animate {
            transform: scale(1);
        }
        
        .theme-transition-circle.light.animate {
            animation: expandCircleLight 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }
        
        .theme-transition-circle.dark.animate {
            animation: expandCircleDark 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }
        
        @keyframes expandCircleLight {
            0% {
                transform: scale(0);
                opacity: 1;
            }
            100% {
                transform: scale(100);
                opacity: 0;
            }
        }
        
        @keyframes expandCircleDark {
            0% {
                transform: scale(0);
                opacity: 1;
            }
            100% {
                transform: scale(100);
                opacity: 0;
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Geekspace</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Resource" asp-action="Index">Resources</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Category" asp-action="Index">Categories</a>
                            </li>
                        </ul>

                        <div class="d-flex align-items-center">
                            <button id="themeToggle" class="btn theme-toggle-btn me-2" type="button" title="Toggle light / dark theme">
                                <span id="themeIcon">🌙</span>
                            </button>
                            <partial name="_LoginPartial" />
                        </div>
                    </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Geekspace - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toggleBtn = document.getElementById('themeToggle');
            var icon = document.getElementById('themeIcon');
            var html = document.documentElement;

            function updateIcon() {
                icon.textContent = html.getAttribute('data-bs-theme') === 'dark' ? '☀️' : '🌙';
            }
            updateIcon();

            toggleBtn.addEventListener('click', function (e) {
                var currentTheme = html.getAttribute('data-bs-theme');
                var nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
                
                // Get button position
                var rect = toggleBtn.getBoundingClientRect();
                var centerX = rect.left + rect.width / 2;
                var centerY = rect.top + rect.height / 2;
                
                // Calculate the maximum radius needed to cover the viewport
                var maxRadius = Math.max(
                    Math.hypot(centerX, centerY),
                    Math.hypot(window.innerWidth - centerX, centerY),
                    Math.hypot(centerX, window.innerHeight - centerY),
                    Math.hypot(window.innerWidth - centerX, window.innerHeight - centerY)
                );
                
                // Create circle element
                var circle = document.createElement('div');
                circle.className = 'theme-transition-circle ' + nextTheme;
                circle.style.width = maxRadius * 2 + 'px';
                circle.style.height = maxRadius * 2 + 'px';
                circle.style.left = (centerX - maxRadius) + 'px';
                circle.style.top = (centerY - maxRadius) + 'px';
                document.body.appendChild(circle);
                
                // Trigger animation
                requestAnimationFrame(function() {
                    circle.classList.add('animate');
                });
                
                // Apply theme change
                html.setAttribute('data-bs-theme', nextTheme);
                localStorage.setItem('geekspace-theme', nextTheme);
                updateIcon();
                
                // Remove circle after animation
                setTimeout(function() {
                    circle.remove();
                }, 600);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
